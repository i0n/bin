. ~/bin/dotfiles/zsh/config
. ~/bin/dotfiles/zsh/aliases

unsetopt correct_all

export PYENV_ROOT="$HOME/.pyenv"
export PATH="$PYENV_ROOT/bin:$PATH"
eval "$(pyenv init --path)"

export NVM_DIR="$HOME/.nvm"
  [ -s "/opt/homebrew/opt/nvm/nvm.sh" ] && \. "/opt/homebrew/opt/nvm/nvm.sh"  # This loads nvm
  [ -s "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm" ] && \. "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm"  # This loads nvm bash_completion

export PATH="$HOME/.cargo/bin:/usr/local/bin:opt/homebrew/bin/brew:$HOME/bin:$HOME/go/bin:/opt/homebrew/opt/postgresql@16/bin:$HOME/.local/share/solana/install/active_release/bin:$HOME/.antigravity/antigravity/bin:$HOME/.local/bin:$PATH"


# starship
eval "$(starship init zsh)"


